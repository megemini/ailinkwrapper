{
  "manifest_version": 3,
  "name": "AI Link Wrapper",
  "version": "1.0.0",
  "description": "Open links through configured proxy/wrapper URLs",
  "permissions": [
    "contextMenus",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Link Proxy Opener",
    "default_icon": "images/logo.png"
  },
  "icons": {
    "128": "images/logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
